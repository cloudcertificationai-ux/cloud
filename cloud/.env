# ─── Email (admin notifications) ──────────────────────────────────────────────
# Option A: Resend REST API (recommended — no extra package needed)
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=""

# Option B: SMTP fallback (Gmail, SendGrid SMTP, Postmark, etc.)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

EMAIL_FROM="noreply@anywheredoor.com"
ADMIN_NOTIFICATION_EMAIL="admin@anywheredoor.com"

# ─── Security ─────────────────────────────────────────────────────────────────
# 32-character keys — generate with: openssl rand -hex 16
ENCRYPTION_KEY="d120df172b88330e555b14fa66206431"
JWT_SIGNING_KEY="53e5f005ae901e88b839fc0651a996f5924284a780a128daaab35a2317ea58fe"

# IP allowlist for sensitive endpoints (comma-separated IPs/CIDRs)
IP_WHITELIST="127.0.0.1,::1"

# Rate limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Session configuration
SESSION_MAX_AGE="86400"
SESSION_UPDATE_AGE="3600"

# ─── Audit Logging ────────────────────────────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS="90"
AUDIT_LOG_LEVEL="info"

